# FINNY — Variables de entorno
# Copia este archivo como .env para desarrollo local.
# En Vercel, agrega estas variables en Project Settings > Environment Variables.

# ── REQUERIDA en producción ────────────────────────────────────────────────────
# Clave secreta para sesiones Flask. Genera una con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esto-por-una-clave-segura-de-32-chars

# ── BASE DE DATOS ──────────────────────────────────────────────────────────────
# Opción A: SQLite local (default si no se define ninguna)
# No se necesita variable — usa backend/finny.db automáticamente

# Opción B: PostgreSQL (Neon, Railway, Supabase)
# DATABASE_URL=postgresql://user:password@host/dbname

# Opción C: MySQL (PlanetScale, Railway)
# DATABASE_URL=mysql+pymysql://user:password@host:3306/dbname

# ── CORS (opcional) ────────────────────────────────────────────────────────────
# URL del frontend si usas un dominio custom
# FRONTEND_URL=https://mi-finny.vercel.app

# ── ENTORNO ────────────────────────────────────────────────────────────────────
FLASK_ENV=development
